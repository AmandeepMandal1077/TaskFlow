// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique

  boards Board[]
  assignedCards Card[] @relation("CardAssignees")

}

model Board {
  id          String  @id @default(uuid())
  title       String
  description String?
  color       String  @default("#FFFFFF")

  user_id    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  lists List[]

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model List {
  id    String @id @default(uuid())
  title String
  order Int    @default(0)

  board_id   String
  created_at DateTime @default(now())

  cards Card[]

  board Board @relation(fields: [board_id], references: [id], onDelete: Cascade)
}

model Card {
  id          String  @id @default(uuid())
  title       String
  description String?
  order       Int     @default(0)
  is_complete Boolean @default(false)

  due_date   DateTime?
  list_id    String
  created_at DateTime  @default(now())

  list List @relation(fields: [list_id], references: [id], onDelete: Cascade)

  assignees  User[]      @relation("CardAssignees")
  labels     Label[]     @relation("CardLabels")
  checklists Checklist[]
}

model Label {
  id    String @id @default(uuid())
  name  String
  color String

  cards Card[] @relation("CardLabels")
}

model Checklist {
  id      String @id @default(uuid())
  title   String
  card_id String

  card  Card            @relation(fields: [card_id], references: [id], onDelete: Cascade)
  items ChecklistItem[]
}

model ChecklistItem {
  id           String  @id @default(uuid())
  title        String
  is_checked   Boolean @default(false)
  checklist_id String

  checklist Checklist @relation(fields: [checklist_id], references: [id], onDelete: Cascade)
}
